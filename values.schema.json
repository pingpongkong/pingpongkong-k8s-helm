{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "pingpongkong Helm values",
  "type": "object",
  "additionalProperties": false,
  "required": ["CONFIG_GIT_URL", "CONFIG_GIT_CLUSTERNAME", "CONFIG_GIT_TOKEN", "logLevel", "matrixConfigMap", "collector", "agent"],
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "CONFIG_GIT_CLUSTERNAME": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "description": "Cluster file stem used to read k8s/{{ CONFIG_GIT_CLUSTERNAME }}.yaml from pingpongkong-state."
    },
    "CONFIG_GIT_URL": {
      "type": "string",
      "format": "uri",
      "minLength": 1,
      "description": "Plain Git repository URL used by the collector."
    },
    "CONFIG_GIT_TOKEN": {
      "type": "string",
      "description": "Git token rendered only into the collector Secret."
    },
    "logLevel": {
      "type": "string",
      "enum": ["TRACE", "DEBUG", "INFO", "WARN", "ERROR"],
      "description": "Log level used by the collector and agent."
    },
    "matrixConfigMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "namespace", "name", "key", "data"],
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create the ConfigMap watched by the agent."
        },
        "namespace": {
          "type": "string",
          "minLength": 1,
          "description": "Namespace containing the matrix ConfigMap."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the matrix ConfigMap."
        },
        "key": {
          "type": "string",
          "minLength": 1,
          "description": "Data key containing the matrix YAML."
        },
        "data": {
          "type": "string",
          "description": "Initial matrix YAML content."
        }
      }
    },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["updateInterval", "apiPort", "image", "resources"],
      "properties": {
        "updateInterval": { "$ref": "#/definitions/duration" },
        "apiPort": { "$ref": "#/definitions/port" },
        "image": { "$ref": "#/definitions/image" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkInterval", "apiPort", "image", "resources"],
      "properties": {
        "checkInterval": { "$ref": "#/definitions/duration" },
        "apiPort": { "$ref": "#/definitions/port" },
        "image": { "$ref": "#/definitions/image" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    }
  },
  "definitions": {
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "description": "Duration string such as 30s, 5m, or 1h."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "description": "TCP port number."
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": { "$ref": "#/definitions/resourceList" },
        "limits": { "$ref": "#/definitions/resourceList" }
      }
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number"]
      }
    },
    "k8sState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "notification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "discord": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
