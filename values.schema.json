{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "pingpongkong Helm values",
  "type": "object",
  "additionalProperties": false,
  "required": ["CONFIG_GIT_URL", "CONFIG_GIT_TOKEN", "CONFIG_GIT_CLUSTERNAME", "LOG_LEVEL", "COLLECTOR_UPDATE_INTERVAL", "REPORT_NOTIFICATION_MODE", "AGENT_CHECK_INTERVAL", "AGENT_API_PORT", "COLLECTOR_API_PORT", "collector", "agent"],
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "CONFIG_GIT_CLUSTERNAME": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "description": "Cluster directory/file stem used to read k8s/{{ CONFIG_GIT_CLUSTERNAME }}.yaml from pingpongkong-state and build the ping-state ConfigMap name."
    },
    "CONFIG_GIT_URL": {
      "type": "string",
      "format": "uri",
      "minLength": 1,
      "pattern": "^.+\\.git$",
      "description": "Plain Git repository URL used by the collector. Must end with .git."
    },
    "CONFIG_GIT_TOKEN": {
      "type": "string",
      "description": "Git token rendered only into the collector Secret."
    },
    "LOG_LEVEL": {
      "type": "string",
      "enum": ["TRACE", "DEBUG", "INFO", "WARN", "ERROR"],
      "description": "Log level used by the collector and agent."
    },
    "COLLECTOR_UPDATE_INTERVAL": { "$ref": "#/definitions/duration" },
    "REPORT_NOTIFICATION_MODE": {
      "type": "string",
      "enum": ["ALWAYS", "NON_HEALTHY"],
      "description": "Periodic connectivity report notification mode. Use ALWAYS to notify for every report or NON_HEALTHY to notify only when aggregate report health is not Healthy."
    },
    "AGENT_CHECK_INTERVAL": { "$ref": "#/definitions/duration" },
    "AGENT_API_PORT": { "$ref": "#/definitions/port" },
    "COLLECTOR_API_PORT": { "$ref": "#/definitions/port" },
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "resources"],
      "properties": {
        "image": { "$ref": "#/definitions/image" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "resources"],
      "properties": {
        "image": { "$ref": "#/definitions/image" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    }
  },
  "definitions": {
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(s|m|h)$",
      "description": "Duration string such as 30s, 5m, or 1h."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "description": "TCP port number."
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": { "$ref": "#/definitions/resourceList" },
        "limits": { "$ref": "#/definitions/resourceList" }
      }
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number"]
      }
    },
    "k8sState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "notification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "discord": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
